page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮 */
.btn-primary {
  display: inline-block;
  background: linear-gradient(135deg, #3D7BFF, #5B9AFF);
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-outline {
  display: inline-block;
  background: #fff;
  color: #3D7BFF;
  border: 2rpx solid #3D7BFF;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
}
.btn-danger {
  display: inline-block;
  background: #FF4757;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
}

/* 价格 */
.price {
  color: #FF4757;
  font-size: 36rpx;
  font-weight: 700;
}
.price-symbol {
  font-size: 24rpx;
  font-weight: 400;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}
.tag-blue {
  background: #E8F0FF;
  color: #3D7BFF;
}
.tag-green {
  background: #E8FFF0;
  color: #2ED573;
}
.tag-orange {
  background: #FFF3E8;
  color: #FF9F43;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

/* 状态文字 */
.status-pending { color: #FF9F43; }
.status-paid { color: #3D7BFF; }
.status-done { color: #2ED573; }
.status-cancel { color: #999; }
