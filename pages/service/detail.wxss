.page-detail {
  padding-bottom: 120rpx;
}

.detail-cover {
  width: 100%;
  height: 500rpx;
  background: #e8e8e8;
}

.detail-header {
  margin: -20rpx 20rpx 16rpx;
  position: relative;
  z-index: 1;
}
.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}
.detail-tags {
  margin-bottom: 16rpx;
}
.detail-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.meta-items {
  display: flex;
  gap: 20rpx;
}
.meta-item {
  font-size: 24rpx;
  color: #999;
}

.detail-section {
  margin: 0 20rpx 16rpx;
}
.section-label {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: block;
}
.detail-content, .notes-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.bottom-price {
  display: flex;
  align-items: baseline;
}
.bottom-bar .btn-primary {
  padding: 16rpx 64rpx;
}
