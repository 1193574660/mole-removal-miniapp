<!-- 聊天详情页 -->
<view class="page-chat">
  <!-- 消息列表 -->
  <scroll-view
    class="msg-list"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    bindscrolltoupper="onReachBottom"
    style="padding-bottom: {{keyboardHeight + 100}}rpx"
  >
    <view wx:if="{{loading && messages.length === 0}}" class="load-more">加载中...</view>
    <view wx:elif="{{!hasMore && messages.length > 0}}" class="load-more">— 以上是历史消息 —</view>

    <view class="msg-item {{item.user_id === 'self' ? 'msg-self' : 'msg-other'}}"
          wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <!-- 对方头像 -->
      <image wx:if="{{item.user_id !== 'self'}}" class="msg-avatar"
             src="{{item.avatar || '/images/default-doctor.png'}}" mode="aspectFill" />

      <view class="msg-body {{item.user_id === 'self' ? 'msg-body-self' : 'msg-body-other'}}">
        <!-- 文字消息 -->
        <view class="msg-text" wx:if="{{item.msg_type === 1}}">
          <text>{{item.content}}</text>
          <text wx:if="{{item.sending}}" class="msg-sending">发送中...</text>
          <text wx:if="{{item.sendFail}}" class="msg-fail">发送失败</text>
        </view>
        <!-- 图片消息 -->
        <image wx:if="{{item.msg_type === 2}}"
               class="msg-image {{item.sending ? 'msg-sending' : ''}}"
               src="{{item.image_url}}"
               mode="widthFix"
               bindtap="previewImage" data-url="{{item.image_url}}" />
      </view>

      <!-- 自己头像 -->
      <image wx:if="{{item.user_id === 'self'}}" class="msg-avatar msg-avatar-self"
             src="{{item.my_avatar || '/images/default-avatar.png'}}" mode="aspectFill" />

      <text class="msg-time">{{item.time_str}}</text>
    </view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <view class="input-actions">
      <text class="action-btn" bindtap="chooseImage">📷</text>
    </view>
    <input class="msg-input" placeholder="输入消息..."
           value="{{inputValue}}" bindinput="onInput"
           confirm-type="send" bindconfirm="sendText"
           adjust-position="{{false}}" />
    <button class="send-btn" bindtap="sendText" disabled="{{!inputValue.trim()}}">发送</button>
  </view>
</view>
