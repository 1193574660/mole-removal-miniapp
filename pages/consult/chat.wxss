.page-chat {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.msg-list {
  flex: 1;
  padding: 20rpx;
}

.msg-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
  position: relative;
}
.msg-self {
  flex-direction: row-reverse;
}
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e8f0ff;
  flex-shrink: 0;
}
.msg-avatar-self {
  background: #e8e8ff;
}

.msg-body {
  max-width: 65%;
  margin: 0 16rpx;
}
.msg-body-self {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.msg-body-other {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.msg-text {
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
  position: relative;
}
.msg-body-other .msg-text {
  background: #fff;
  border-top-left-radius: 4rpx;
}
.msg-body-self .msg-text {
  background: #3D7BFF;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.msg-image {
  max-width: 400rpx;
  border-radius: 12rpx;
}
.msg-sending { opacity: 0.6; }

.msg-sending-text, .msg-fail {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
.msg-fail { color: #FF4757; }

.msg-time {
  font-size: 20rpx;
  color: #ccc;
  position: absolute;
  bottom: -28rpx;
  left: 90rpx;
}
.msg-self .msg-time {
  left: auto;
  right: 90rpx;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  gap: 12rpx;
}
.action-btn {
  font-size: 40rpx;
  padding: 0 10rpx;
}
.msg-input {
  flex: 1;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
.send-btn {
  background: #3D7BFF;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 34rpx;
  border: none;
  line-height: 1.4;
}
.send-btn[disabled] {
  background: #ccc;
}
