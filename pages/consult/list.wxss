.page-consult-list {
  min-height: 100vh;
}

.session-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.session-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #e8f0ff;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.session-body {
  flex: 1;
  min-width: 0;
}
.session-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.session-name {
  font-size: 30rpx;
  font-weight: 600;
}
.session-time {
  font-size: 22rpx;
  color: #bbb;
}
.session-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.session-preview {
  font-size: 26rpx;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.session-badge {
  background: #FF4757;
  color: #fff;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  padding: 0 8rpx;
  margin-left: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}
