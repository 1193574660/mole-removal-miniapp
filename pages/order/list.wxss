.page-order-list {
  min-height: 100vh;
}

/* Tab */
.tab-bar {
  display: flex;
  background: #fff;
  white-space: nowrap;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab-item {
  display: inline-block;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}
.tab-item.active {
  color: #3D7BFF;
  border-bottom-color: #3D7BFF;
  font-weight: 600;
}

/* 订单卡片 */
.order-card {
  margin: 16rpx 20rpx;
}
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-service {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #f0f0f0;
  margin-bottom: 12rpx;
}
.order-service-name {
  font-size: 30rpx;
  font-weight: 600;
}
.order-service-price {
  font-size: 32rpx;
  color: #FF4757;
  font-weight: 600;
}

.order-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}
.small {
  padding: 8rpx 28rpx !important;
  font-size: 24rpx !important;
}
