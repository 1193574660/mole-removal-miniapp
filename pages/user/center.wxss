.page-user-center {
  min-height: 100vh;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #3D7BFF, #6B9FFF);
  margin-bottom: 16rpx;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 24rpx;
  background: rgba(255,255,255,0.3);
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}
.user-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}
.user-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.6);
}

.menu-section {
  background: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-name { flex: 1; font-size: 28rpx; }
.menu-badge { font-size: 22rpx; color: #999; margin-right: 8rpx; }
.menu-arrow { font-size: 32rpx; color: #ccc; }

.logout-section {
  margin-top: 48rpx;
  padding: 0 32rpx;
}
.logout-btn {
  width: 100%;
  background: #fff;
  color: #FF4757;
  font-size: 28rpx;
  border: 1rpx solid #FF4757;
  border-radius: 44rpx;
  padding: 16rpx 0;
}
