.page-profile {
  min-height: 100vh;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
  background: #fff;
  margin-bottom: 16rpx;
}
.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-bottom: 16rpx;
}
.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

.form-section {
  margin: 0 20rpx;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.phone-btn {
  flex: 1;
  background: #3D7BFF;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  padding: 16rpx;
  text-align: center;
  border: none;
}

.save-section {
  margin: 48rpx 32rpx;
}
.full-width { width: 100%; }
